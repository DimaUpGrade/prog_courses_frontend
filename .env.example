# Скопируйте этот файл в .env (для docker-compose) и/или .env.local
# (для локального запуска vue-cli-service serve).

# Адрес backend API. Если backend поднят через свой docker-compose.yaml
# с портом 8000, опубликованным на хосте, оставьте как есть --
# браузер пользователя обращается к API напрямую по этому адресу.
VUE_APP_API_URL=http://127.0.0.1:8000

# Порт, на котором будет доступен фронтенд на хост-машине
FRONTEND_PORT=8080
